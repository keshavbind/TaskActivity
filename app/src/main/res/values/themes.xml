<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.TaskActivity" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Primary brand colors -->
        <item name="colorPrimary">@color/primary</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorPrimaryContainer">@color/primary_dark</item>
        <item name="colorOnPrimaryContainer">@color/white</item>

        <!-- Secondary brand colors -->
        <item name="colorSecondary">@color/secondary</item>
        <item name="colorOnSecondary">@color/black</item>

        <!-- Background and Surface -->
        <item name="android:colorBackground">@color/bg_dark</item>
        <item name="colorSurface">@color/bg_surface</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="colorSurfaceVariant">@color/bg_surface_elevated</item>
        <item name="colorOnSurfaceVariant">@color/text_secondary</item>

        <!-- Error -->
        <item name="colorError">@color/error</item>
        <item name="colorOnError">@color/white</item>

        <!-- System bars -->
        <item name="android:statusBarColor">@color/status_bar</item>
        <item name="android:navigationBarColor">@color/bg_dark</item>
        <item name="android:windowLightStatusBar" tools:targetApi="m">false</item>

        <!-- Window -->
        <item name="android:windowBackground">@color/bg_dark</item>

        <!-- Default widget styles -->
        <item name="materialCardViewStyle">@style/TaskCard</item>
        <item name="floatingActionButtonStyle">@style/TaskFab</item>
    </style>

    <style name="Theme.TaskActivity" parent="Base.Theme.TaskActivity" />

    <!-- Card Style -->
    <style name="TaskCard" parent="Widget.Material3.CardView.Filled">
        <item name="cardCornerRadius">@dimen/card_corner</item>
        <item name="cardElevation">@dimen/card_elevation</item>
        <item name="cardBackgroundColor">@color/bg_card</item>
    </style>

    <!-- FAB Style -->
    <style name="TaskFab" parent="Widget.Material3.FloatingActionButton.Primary">
        <item name="backgroundTint">@color/primary</item>
        <item name="tint">@color/white</item>
        <item name="elevation">@dimen/fab_elevation</item>
        <item name="shapeAppearanceOverlay">@style/FabShape</item>
    </style>

    <style name="FabShape" parent="">
        <item name="cornerSize">@dimen/radius_lg</item>
    </style>

    <!-- Button Style -->
    <style name="PrimaryButton" parent="Widget.Material3.Button">
        <item name="android:textColor">@color/white</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textSize">@dimen/text_subtitle</item>
        <item name="android:textAllCaps">false</item>
        <item name="cornerRadius">@dimen/button_corner</item>
        <item name="backgroundTint">@color/primary</item>
        <item name="android:minHeight">@dimen/button_height</item>
    </style>

    <!-- Text Input Style -->
    <style name="TaskTextInput" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="boxStrokeColor">@color/border_input_focused</item>
        <item name="boxStrokeWidthFocused">2dp</item>
        <item name="boxCornerRadiusTopStart">@dimen/radius_md</item>
        <item name="boxCornerRadiusTopEnd">@dimen/radius_md</item>
        <item name="boxCornerRadiusBottomStart">@dimen/radius_md</item>
        <item name="boxCornerRadiusBottomEnd">@dimen/radius_md</item>
        <item name="hintTextColor">@color/primary</item>
        <item name="android:textColorHint">@color/text_hint</item>
        <item name="boxBackgroundColor">@color/bg_surface_elevated</item>
    </style>

    <!-- Toolbar Title -->
    <style name="ToolbarTitle">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textSize">@dimen/text_title</item>
        <item name="android:textStyle">bold</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <!-- Headline -->
    <style name="Headline">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textSize">@dimen/text_headline</item>
        <item name="android:textStyle">bold</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>
</resources>